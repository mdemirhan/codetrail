{
  "name": "codetrail",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <24",
    "bun": ">=1.1"
  },
  "overrides": {
    "node-gyp": "^12.1.0"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "install": "echo \"Dependencies are managed by 'bun install'.\"",
    "check:platform-boundaries": "node ./scripts/check-platform-boundaries.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:unused": "tsc -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
    "test": "node ./scripts/run-vitest-under-electron.mjs run",
    "test:coverage": "node ./scripts/run-vitest-under-electron.mjs run --coverage",
    "test:watch": "node ./scripts/run-vitest-under-electron.mjs",
    "desktop:build": "bun run --cwd apps/desktop build",
    "desktop:build:icons": "bun run --cwd apps/desktop build:icons",
    "desktop:bench:message-viewer": "bun run --cwd apps/desktop bench:message-viewer",
    "desktop:start": "bun run --cwd apps/desktop start",
    "desktop:start:compare": "bun run --cwd apps/desktop start:compare",
    "desktop:start:verbose": "bun run --cwd apps/desktop start:verbose",
    "desktop:start:verbose:compare": "bun run --cwd apps/desktop start:verbose:compare",
    "desktop:dev": "bun run --cwd apps/desktop start",
    "desktop:dev:compare": "bun run --cwd apps/desktop dev:compare",
    "desktop:verify:native": "bun run --cwd apps/desktop verify:native",
    "desktop:rebuild:native": "bun run --cwd apps/desktop rebuild:native",
    "desktop:fix:native": "bun run --cwd apps/desktop fix:native",
    "desktop:make:mac": "bun run --cwd apps/desktop make:mac",
    "desktop:make:mac:x64": "bun run --cwd apps/desktop make:mac:x64",
    "desktop:make:mac:arm64": "bun run --cwd apps/desktop make:mac:arm64",
    "e2e": "bun run desktop:build && npx playwright test --config e2e/playwright.config.ts",
    "e2e:headed": "bun run desktop:build && HEADED=1 npx playwright test --config e2e/playwright.config.ts",
    "e2e:report": "npx playwright show-report e2e/playwright-report",
    "desktop:make:win": "bun run --cwd apps/desktop make:win",
    "ci": "bun run lint && bun run check:platform-boundaries && bun run typecheck && bun run test && bun run test:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.13.10",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@vitest/coverage-v8": "3.0.8",
    "jsdom": "^28.1.0",
    "typescript": "5.8.2",
    "vitest": "3.0.8"
  }
}
