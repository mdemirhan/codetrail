{
  "name": "@codetrail/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "build:icons": "node ./scripts/build-app-icons.mjs",
    "bench:message-viewer": "bun ./scripts/measure-message-viewer-performance.tsx",
    "verify:native": "ELECTRON_RUN_AS_NODE=1 electron -e \"const Database=require('better-sqlite3'); const db=new Database(':memory:'); db.prepare('select 1').get(); db.close(); require('@parcel/watcher'); console.log('native modules ABI OK')\"",
    "rebuild:native": "bun ./scripts/rebuild-native.ts",
    "fix:native": "bun run verify:native || bun run rebuild:native",
    "prestart": "bun run build && bun run fix:native",
    "prestart:compare": "bun run prestart",
    "prestart:verbose:compare": "bun run prestart",
    "predev": "bun run prestart",
    "predev:compare": "bun run prestart",
    "start": "electron .",
    "start:compare": "electron . --instance=compare",
    "start:verbose": "electron . --verbose",
    "start:verbose:compare": "electron . --instance=compare --verbose",
    "dev": "electron .",
    "dev:compare": "electron . --instance=compare",
    "make:mac": "./scripts/make-macos-app.sh",
    "make:mac:x64": "./scripts/make-macos-app.sh x64",
    "make:mac:arm64": "./scripts/make-macos-app.sh arm64",
    "make:win": "node ./scripts/make-windows-app.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@parcel/watcher": "^2.5.6",
    "better-sqlite3": "11.8.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.13.0"
  },
  "devDependencies": {
    "@codetrail/core": "workspace:*",
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron/rebuild": "^4.0.3",
    "electron": "35.0.0",
    "png2icons": "^2.0.1"
  }
}
